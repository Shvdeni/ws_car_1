<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="touch_car">
  <xacro:property name="body_length" value="0.13"/>
  <xacro:property name="body_width" value="0.10"/>
  <xacro:property name="body_height" value="0.045"/>
  <xacro:property name="wheel_radius" value="0.025"/>
  <xacro:property name="wheel_width" value="0.018"/>
  <xacro:property name="wheel_y" value="0.060"/>
  <xacro:property name="rear_x" value="-0.045"/>
  <xacro:property name="front_x" value="0.055"/>
  <xacro:property name="bumper_x" value="0.075"/>
  <xacro:property name="camera_x" value="0.135"/>

  <material name="blue">
    <color rgba="0.10 0.28 0.75 1.0"/>
  </material>
  <material name="dark">
    <color rgba="0.02 0.02 0.025 1.0"/>
  </material>
  <material name="bumper_red">
    <color rgba="0.85 0.08 0.06 1.0"/>
  </material>
  <material name="camera_dark">
    <color rgba="0.02 0.02 0.025 1.0"/>
  </material>

  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + body_height / 2.0}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00045" ixy="0" ixz="0" iyy="0.00075" iyz="0" izz="0.0010"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
  </link>

  <xacro:macro name="drive_wheel" params="prefix y">
    <link name="${prefix}_wheel_link">
      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="0.06"/>
        <inertia ixx="0.00002" ixy="0" ixz="0" iyy="0.00002" iyz="0" izz="0.00002"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${rear_x} ${y} ${-body_height / 2.0}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="left" y="${wheel_y}"/>
  <xacro:drive_wheel prefix="right" y="${-wheel_y}"/>

  <link name="caster_wheel_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
      <material name="dark"/>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.018"/>
      </geometry>
    </collision>
  </link>
  <joint name="caster_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel_link"/>
    <origin xyz="${front_x} 0 ${-body_height / 2.0 - 0.004}" rpy="0 0 0"/>
  </joint>

  <link name="front_bumper_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.080 0.115 0.025"/>
      </geometry>
      <material name="bumper_red"/>
    </visual>
    <collision name="front_bumper_collision">
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.080 0.115 0.025"/>
      </geometry>
    </collision>
  </link>
  <joint name="front_bumper_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_bumper_link"/>
    <origin xyz="${bumper_x} 0 0.005" rpy="0 0 0"/>
  </joint>

  <link name="front_camera_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.01"/>
      <inertia ixx="0.000001" ixy="0" ixz="0" iyy="0.000001" iyz="0" izz="0.000001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <box size="0.024 0.032 0.022"/>
      </geometry>
      <material name="camera_dark"/>
    </visual>
  </link>
  <joint name="front_camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_camera_link"/>
    <origin xyz="${camera_x} 0 0.0375" rpy="0 0 0"/>
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="caster_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
  </gazebo>
  <gazebo reference="front_bumper_link">
    <material>Gazebo/Red</material>
    <sensor name="front_bumper_sensor" type="contact">
      <always_on>true</always_on>
      <update_rate>30</update_rate>
      <contact>
        <collision>base_footprint_fixed_joint_lump__front_bumper_collision_collision_2</collision>
        <topic>/touch_car/bumper_contacts</topic>
      </contact>
    </sensor>
  </gazebo>
  <gazebo reference="front_camera_link">
    <material>Gazebo/Black</material>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${2.0 * wheel_y}</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <max_linear_acceleration>0.4</max_linear_acceleration>
      <min_linear_acceleration>-0.4</min_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <min_angular_acceleration>-2.0</min_angular_acceleration>
      <max_linear_velocity>0.15</max_linear_velocity>
      <min_linear_velocity>-0.15</min_linear_velocity>
      <max_angular_velocity>1.2</max_angular_velocity>
      <min_angular_velocity>-1.2</min_angular_velocity>
    </plugin>
  </gazebo>
</robot>
