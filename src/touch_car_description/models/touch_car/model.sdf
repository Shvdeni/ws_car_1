<?xml version="1.0"?>
<sdf version="1.9">
  <model name="touch_car">
    <pose>0 0 0 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>0.45</mass>
        <inertia>
          <ixx>0.00045</ixx>
          <iyy>0.00075</iyy>
          <izz>0.0010</izz>
        </inertia>
      </inertial>
      <collision name="base_collision">
        <pose>0 0 0.0475 0 0 0</pose>
        <geometry>
          <box>
            <size>0.13 0.10 0.045</size>
          </box>
        </geometry>
      </collision>
      <visual name="base_visual">
        <pose>0 0 0.0475 0 0 0</pose>
        <geometry>
          <box>
            <size>0.13 0.10 0.045</size>
          </box>
        </geometry>
        <material>
          <ambient>0.10 0.28 0.75 1</ambient>
          <diffuse>0.10 0.28 0.75 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="left_wheel_link">
      <pose>-0.045 0.060 0.025 1.57079632679 0 0</pose>
      <inertial>
        <mass>0.06</mass>
        <inertia>
          <ixx>0.00002</ixx>
          <iyy>0.00002</iyy>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <collision name="left_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.018</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="left_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.018</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.02 0.02 0.025 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="right_wheel_link">
      <pose>-0.045 -0.060 0.025 1.57079632679 0 0</pose>
      <inertial>
        <mass>0.06</mass>
        <inertia>
          <ixx>0.00002</ixx>
          <iyy>0.00002</iyy>
          <izz>0.00002</izz>
        </inertia>
      </inertial>
      <collision name="right_wheel_collision">
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.018</length>
          </cylinder>
        </geometry>
      </collision>
      <visual name="right_wheel_visual">
        <geometry>
          <cylinder>
            <radius>0.025</radius>
            <length>0.018</length>
          </cylinder>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.02 0.02 0.025 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="caster_wheel_link">
      <pose>0.055 0 0.021 0 0 0</pose>
      <inertial>
        <mass>0.03</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <iyy>0.00001</iyy>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <collision name="caster_collision">
        <geometry>
          <sphere>
            <radius>0.018</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.05</mu>
              <mu2>0.05</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name="caster_visual">
        <geometry>
          <sphere>
            <radius>0.018</radius>
          </sphere>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.025 1</ambient>
          <diffuse>0.02 0.02 0.025 1</diffuse>
        </material>
      </visual>
    </link>

    <link name="front_bumper_link">
      <pose>0.075 0 0.0525 0 0 0</pose>
      <inertial>
        <mass>0.02</mass>
        <inertia>
          <ixx>0.00001</ixx>
          <iyy>0.00001</iyy>
          <izz>0.00001</izz>
        </inertia>
      </inertial>
      <collision name="front_bumper_collision">
        <geometry>
          <box>
            <size>0.080 0.115 0.025</size>
          </box>
        </geometry>
      </collision>
      <visual name="front_bumper_visual">
        <geometry>
          <box>
            <size>0.080 0.115 0.025</size>
          </box>
        </geometry>
        <material>
          <ambient>0.85 0.08 0.06 1</ambient>
          <diffuse>0.85 0.08 0.06 1</diffuse>
        </material>
      </visual>
      <sensor name="front_bumper_sensor" type="contact">
        <always_on>true</always_on>
        <update_rate>30</update_rate>
        <contact>
          <collision>front_bumper_collision</collision>
          <topic>/touch_car/bumper_contacts</topic>
        </contact>
      </sensor>
    </link>

    <joint name="left_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>left_wheel_link</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>base_link</parent>
      <child>right_wheel_link</child>
      <axis>
        <xyz>0 0 -1</xyz>
        <limit>
          <lower>-1e16</lower>
          <upper>1e16</upper>
        </limit>
      </axis>
    </joint>

    <joint name="caster_wheel_joint" type="fixed">
      <parent>base_link</parent>
      <child>caster_wheel_link</child>
    </joint>

    <joint name="front_bumper_joint" type="fixed">
      <parent>base_link</parent>
      <child>front_bumper_link</child>
    </joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.12</wheel_separation>
      <wheel_radius>0.025</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <max_linear_acceleration>0.4</max_linear_acceleration>
      <min_linear_acceleration>-0.4</min_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <min_angular_acceleration>-2.0</min_angular_acceleration>
      <max_linear_velocity>0.15</max_linear_velocity>
      <min_linear_velocity>-0.15</min_linear_velocity>
      <max_angular_velocity>1.2</max_angular_velocity>
      <min_angular_velocity>-1.2</min_angular_velocity>
    </plugin>
  </model>
</sdf>
